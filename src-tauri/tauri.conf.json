{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JNApp",
  "version": "1.20.3",
  "identifier": "com.jesus.jnapp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JNApp",
        "width": 420,
        "height": 800,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4ODMxNzIyQTNDRTJBMDMKUldRREtzNmpJaGVEbUNtRHRHblAreXY1bDVqZSs0ZnNFU28ralF6Qk1CNmo3MGh2cTBEdHJnQWIK",
      "endpoints": [
        "https://github.com/DogitoMB2006/jnapp/releases/latest/download/latest.json"
      ]
    }
  }
}
